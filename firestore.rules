rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
       return isSignedIn() && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }
    
    // Helper to fetch the user's mapping document once
    function getApprovedUser() {
      let email = (request.auth.token != null && request.auth.token.email != null) ? request.auth.token.email.lower() : "";
      let userPath = /databases/$(database)/documents/approved_users/$(email);
      return exists(userPath) ? get(userPath).data : null;
    }

    function userCompanyId() {
      let user = getApprovedUser();
      return user != null ? user.companyId : "NONE";
    }

    function isManager() {
      let user = getApprovedUser();
      // Case-insensitive check: handles "manager", "Manager", "MANAGER"
      return user != null && (user.role == "manager" || user.role == "Manager" || user.role == "MANAGER");
    }

    function isOwner(employeeId) {
      return isSignedIn() && 
             (request.auth.token != null && request.auth.token.email != null) && 
             request.auth.token.email.lower() == employeeId.lower();
    }

    // --- RULES ---

    // 1. Global mapping used during login - Force Case-Insensitive Deploy
    match /approved_users/{email} {
      allow read: if isSignedIn() && (
        isOwner(email) || 
        isManager() ||  // Managers need to check if an email is already registered
        (resource != null && resource.data.companyId == userCompanyId()) || 
        isAdmin()
      );
      
      // Managers can create new employee approved_user mappings
      allow create: if isAdmin() || (isSignedIn() && (
        (isManager() && request.resource.data.companyId == userCompanyId()) ||
        (isOwner(email) && 
         get(/databases/$(database)/documents/approved_companies/$(request.resource.data.companyId)).data.managerEmail.lower() == email.lower() &&
         (request.resource.data.role == "manager" || request.resource.data.role == "Manager" || request.resource.data.role == "MANAGER"))
      ));

      // Users can only update their own entry without changing role/companyId
      allow update: if isAdmin() || (
        isSignedIn() && isOwner(email) &&
        // Prevent modification of critical fields
        request.resource.data.role == resource.data.role &&
        request.resource.data.companyId == resource.data.companyId
      );

      allow delete: if isAdmin() || (isSignedIn() && isManager() && resource.data.companyId == userCompanyId());
    }
    
    match /admin_users/{uid} {
       allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    match /company_users/{uid} {
       allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // --- MAIL EXTENSION ---
    match /mail/{id} {
      allow read, write: if isAdmin();
    }

    // 1.5 Pre-login organization setup requests
    match /organization_setup_requests/{requestId} {
      allow create: if
        request.resource.data.flow == "pre_login_organization_setup" &&
        request.resource.data.status == "pending_admin_setup" &&
        request.resource.data.workspaceStatus == "active" &&
        request.resource.data.organizationName is string &&
        request.resource.data.organizationName.size() > 1 &&
        request.resource.data.contactPerson is string &&
        request.resource.data.contactPerson.size() > 1 &&
        request.resource.data.contactNumber is string &&
        request.resource.data.contactNumber.size() > 5 &&
        request.resource.data.contactEmail is string &&
        request.resource.data.contactEmail.size() > 5 &&
        request.resource.data.addressLine1 is string &&
        request.resource.data.addressLine1.size() > 3 &&
        request.resource.data.city is string &&
        request.resource.data.city.size() > 1 &&
        request.resource.data.state is string &&
        request.resource.data.country is string &&
        request.resource.data.postalCode is string &&
        request.resource.data.postalCode.size() > 3 &&
        request.resource.data.timeZone is string &&
        request.resource.data.organizationType is string &&
        request.resource.data.organizationSize is string;
      allow read, update, delete: if isAdmin();
    }


    // 2. Company master data + ALL subcollections
    match /approved_companies/{companyId} {
      // Company document itself
      allow read: if isSignedIn() && (
        userCompanyId() == companyId || 
        isOwner(resource.data.managerEmail) ||
        isAdmin()
      );
      allow create: if isSignedIn() && isOwner(request.resource.data.managerEmail);
      allow update, delete: if isAdmin() || (isSignedIn() && userCompanyId() == companyId && isManager());

      // ── Users subcollection ──────────────────────────────────────
      match /users/{employeeId} {
        allow read: if isSignedIn() && (
          isOwner(employeeId) ||
          (resource != null && isOwner(resource.data.email)) ||
          userCompanyId() == companyId ||
          isAdmin()
        );
        allow write: if isSignedIn() && (
          ((isOwner(employeeId) || isOwner(request.resource.data.email)) && (resource == null || request.resource.data.role == resource.data.role)) ||
          (userCompanyId() == companyId && isManager()) ||
          isAdmin()
        );

        // ── User Attendance ─────────────────────────────────────────
        // Attendance docs stored at users/{email}/attendance/{date}
        match /attendance/{docId} {
          allow read: if isSignedIn() && (
            isOwner(employeeId) ||
            (userCompanyId() == companyId && isManager()) ||
            isAdmin()
          );
          allow write: if isSignedIn() && (
            isOwner(employeeId) ||
            (userCompanyId() == companyId && isManager()) ||
            isAdmin()
          );
        }

        // ── User Leave Requests ─────────────────────────────────────
        match /leave_requests/{docId} {
          allow read: if isSignedIn() && (
            isOwner(employeeId) ||
            (userCompanyId() == companyId && isManager()) ||
            isAdmin()
          );
          allow create: if isSignedIn() && isOwner(employeeId);
          allow update: if isSignedIn() && (
            (isOwner(employeeId) && request.resource.data.status == resource.data.status) ||
            (userCompanyId() == companyId && isManager()) ||
            isAdmin()
          );
          allow delete: if isSignedIn() && (
            (isOwner(employeeId) && resource.data.status == 'pending') ||
            (userCompanyId() == companyId && isManager()) ||
            isAdmin()
          );
        }

        // ── User Notifications ──────────────────────────────────────
        match /notifications/{docId} {
          allow read: if isSignedIn() && (
            isOwner(employeeId) ||
            (userCompanyId() == companyId && isManager()) ||
            isAdmin()
          );
          allow write: if isSignedIn() && (
            isOwner(employeeId) ||   // Employee marks as read
            (userCompanyId() == companyId && isManager()) ||
            isAdmin()
          );
        }

        // ── User Overtime Requests ──────────────────────────────────
        match /overtime_requests/{docId} {
          allow read: if isSignedIn() && (
            isOwner(employeeId) ||
            (userCompanyId() == companyId && isManager()) ||
            isAdmin()
          );
          allow create: if isSignedIn() && isOwner(employeeId);
          allow update: if isSignedIn() && (
            (isOwner(employeeId) && request.resource.data.status == resource.data.status) ||
            (userCompanyId() == companyId && isManager()) ||
            isAdmin()
          );
          allow delete: if isSignedIn() && (
            (isOwner(employeeId) && resource.data.status == 'pending') ||
            (userCompanyId() == companyId && isManager()) ||
            isAdmin()
          );
        }
      }


      // ── Attendance subcollection ─────────────────────────────────────
      match /attendance/{targetUid} {
        allow read, write: if isSignedIn() && (
          request.auth.uid == targetUid ||
          (userCompanyId() == companyId && isManager()) ||
          isAdmin()
        );

        // Attendance records (daily check-in/out)
        match /records/{recordId} {
          allow read, write: if isSignedIn() && (
            request.auth.uid == targetUid ||
            (userCompanyId() == companyId && isManager()) ||
            isAdmin()
          );
        }
      }

      // ── Leave requests subcollection ─────────────────────────────────
      match /leave_requests/{id} {
        allow read: if isSignedIn() && (
          (resource != null && resource.data.userId == request.auth.uid) ||
          (userCompanyId() == companyId && isManager()) ||
          isAdmin()
        );
        allow create: if isSignedIn() && (
          request.resource.data.userId == request.auth.uid &&
          userCompanyId() == companyId
        );
        allow update: if isSignedIn() && (
          (resource != null && resource.data.userId == request.auth.uid && request.resource.data.status == resource.data.status) ||
          (userCompanyId() == companyId && isManager()) ||
          isAdmin()
        );
        allow delete: if isSignedIn() && (
          (resource != null && resource.data.userId == request.auth.uid && resource.data.status == "pending") ||
          (userCompanyId() == companyId && isManager()) ||
          isAdmin()
        );
      }

      // ── Overtime requests subcollection ──────────────────────────────
      match /overtime_requests/{id} {
        allow read: if isSignedIn() && (
          (resource != null && resource.data.userId == request.auth.uid) ||
          (userCompanyId() == companyId && isManager()) ||
          isAdmin()
        );
        allow create: if isSignedIn() && (
          request.resource.data.userId == request.auth.uid &&
          userCompanyId() == companyId
        );
        allow update: if isSignedIn() && (
          (resource != null && resource.data.userId == request.auth.uid && request.resource.data.status == resource.data.status) ||
          (userCompanyId() == companyId && isManager()) ||
          isAdmin()
        );
        allow delete: if isSignedIn() && (
          (resource != null && resource.data.userId == request.auth.uid && resource.data.status == "pending") ||
          (userCompanyId() == companyId && isManager()) ||
          isAdmin()
        );
      }

      // ── Notifications subcollection ──────────────────────────────────
      match /notifications/{id} {
        allow read: if isSignedIn() && (
          (resource != null && resource.data.userId == request.auth.uid) ||
          (userCompanyId() == companyId && isManager()) ||
          isAdmin()
        );
        allow write: if isSignedIn() && (
          (userCompanyId() == companyId && isManager()) ||
          isAdmin()
        );
      }

      // ── Company Calendar ─────────────────────────────────────────────
      // Manager marks holidays / WFH days; all company members can read.
      match /company_calendar/{eventId} {
        allow read: if isSignedIn() && (userCompanyId() == companyId || isAdmin());
        allow write: if isSignedIn() && (
          (userCompanyId() == companyId && isManager()) ||
          isAdmin()
        );
      }

            // ── Global Notifications ─────────────────────────────────────────
      match /global_notifications/{id} {
        allow read: if isSignedIn() && (userCompanyId() == companyId || isAdmin());
        
        // Allows employees to CREATE (send) notifications to the manager
        allow create: if isSignedIn() && (userCompanyId() == companyId || isAdmin());
        
        // Only managers/admins can UPDATE (mark as read) or DELETE notifications
        allow update, delete: if isSignedIn() && (
          (userCompanyId() == companyId && isManager()) ||
          isAdmin()
        );
      }

    } // end match /approved_companies/{companyId}

    // 3. Collection Group Queries (Essential for Managers using collectionGroup) — v2 fix: 2026-05-18
    match /{path=**}/records/{recordId} {
      allow read: if isSignedIn() && (
        // Managers: auth-token check only (no resource.data needed for list queries)
        (isManager() && userCompanyId() != "NONE") ||
        // Employees: own records only
        (resource != null && resource.data.userId == request.auth.uid) ||
        isAdmin()
      );
      allow write: if isSignedIn() && (
        (resource == null && request.resource.data.userId == request.auth.uid && request.resource.data.companyId == userCompanyId()) ||
        (resource != null && resource.data.userId == request.auth.uid) ||
        (isManager() && userCompanyId() != "NONE") ||
        isAdmin()
      );
    }
    
    // Collection group for user-scoped attendance subcollections
    // e.g. approved_companies/{cid}/users/{email}/attendance/{docId}
    match /{path=**}/attendance/{docId} {
      allow read: if isSignedIn() && (
        // Managers: auth-token check only (no resource.data needed for list queries)
        (isManager() && userCompanyId() != "NONE") ||
        // Employees: own records only
        (resource != null && resource.data.userId == request.auth.uid) ||
        isAdmin()
      );
      allow write: if isSignedIn() && (
        (resource == null && request.resource.data.userId == request.auth.uid && request.resource.data.companyId == userCompanyId()) ||
        (resource != null && resource.data.userId == request.auth.uid) ||
        (isManager() && userCompanyId() != "NONE") ||
        isAdmin()
      );
    }

    match /{path=**}/leave_requests/{requestId} {
      allow read: if isSignedIn() && (
        // Managers: auth-token check only (no resource.data needed for list queries)
        (isManager() && userCompanyId() != "NONE") ||
        // Employees: own records only
        (resource != null && resource.data.userId == request.auth.uid) ||
        isAdmin()
      );
      allow write: if isSignedIn() && (
        (resource == null && request.resource.data.userId == request.auth.uid && request.resource.data.companyId == userCompanyId()) ||
        (resource != null && resource.data.userId == request.auth.uid) ||
        (isManager() && userCompanyId() != "NONE") ||
        isAdmin()
      );
    }

    // 4. Legacy top-level collections (kept for backward compat during migration)
    match /companies/{companyId} {
      // Allow creators, designated managers, and admins to read
      allow read: if isSignedIn() && (
        (resource != null && resource.data.registeredBy == request.auth.uid) || 
        (resource != null && resource.data.managerEmail == request.auth.token.email) ||
        isAdmin()
      );

      // Allow any signed-in user to submit a NEW registration
      allow create: if isSignedIn() && 
        request.resource.data.status == "pending" &&
        request.resource.data.registeredBy == request.auth.uid;

      // Only admins can update status or delete
      allow update: if isAdmin() || (
        isSignedIn() && resource.data.registeredBy == request.auth.uid &&
        request.resource.data.status == resource.data.status // Prevent self-approval
      );
      
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.token.email == userId || 
        (resource != null && resource.data.email == request.auth.token.email) ||
        (resource != null && resource.data.companyId == userCompanyId()) ||
        isAdmin()
      );
      allow write: if isSignedIn() && (
        (request.auth.token.email == userId && (resource == null || request.resource.data.role == resource.data.role)) ||
        (resource == null && request.resource.data.companyId == userCompanyId() && isManager()) ||
        (resource != null && resource.data.companyId == userCompanyId() && isManager()) ||
        isAdmin()
      );
    }

    match /notifications/{id} {
      allow read: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.companyId == userCompanyId() && isManager()) ||
        isAdmin()
      );
      allow write: if isSignedIn() && (
        (resource == null && request.resource.data.companyId == userCompanyId() && isManager()) ||
        (resource != null && resource.data.companyId == userCompanyId() && isManager()) ||
        isAdmin()
      );
    }

    match /leave_requests/{id} {
      allow read: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.companyId == userCompanyId() && isManager()) ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.companyId == userCompanyId()
      );
      allow update: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid && request.resource.data.status == resource.data.status) ||
        (resource != null && resource.data.companyId == userCompanyId() && isManager()) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid && resource.data.status == "pending") ||
        (resource != null && resource.data.companyId == userCompanyId() && isManager()) ||
        isAdmin()
      );
    }

    match /overtime_requests/{id} {
      allow read: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.companyId == userCompanyId() && isManager()) ||
        isAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.companyId == userCompanyId()
      );
      allow update: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid && request.resource.data.status == resource.data.status) ||
        (resource != null && resource.data.companyId == userCompanyId() && isManager()) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid && resource.data.status == "pending") ||
        (resource != null && resource.data.companyId == userCompanyId() && isManager()) ||
        isAdmin()
      );
    }

    // 5. Fallbacks (Closed)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
